        self.minsize(1100, 680)

        self.trajectory_active = False
        self.tara_waiting = False
        self._tara_token = 0

        # Estado de la secuencia de comandos en ejecucion (modo Dinamica/Cuadrado
        # mandan varios comandos P encadenados por la senal END)
        self.command_sequence = deque()
        self.sequence_total = 0
        self.sequence_base_name = "Prueba"
        self.sequence_log = []
        self.sequence_time_ms = 0

        self.data_queue = queue.Queue()
        self.log_queue = queue.Queue()
        self.client = RobotClient(self.data_queue, self._on_status_change, self.log_queue,
                                   self._on_trajectory_end, self._on_tare_ack)

        # Historiales para graficas
        self.traj_x = []
        self.traj_y = []
        self.t0 = None
        self.time_hist = deque(maxlen=TIME_WINDOW_POINTS)
        self.veld_hist = deque(maxlen=TIME_WINDOW_POINTS)
        self.veli_hist = deque(maxlen=TIME_WINDOW_POINTS)
        self.yaw_hist = deque(maxlen=TIME_WINDOW_POINTS)
        self.setpoint_yaw = None  # angulo objetivo del tramo actual
        self.setpoint_vel = None  # velocidad objetivo del tramo actual

        self.last_data = None
        self._setup_style()
        self._build_layout()

        self.after(GUI_REFRESH_MS, self._drain_queue)
        self.after(GUI_REFRESH_MS, self._drain_log_queue)
        self.after(PLOT_REFRESH_MS, self._refresh_plots)
        self.protocol("WM_DELETE_WINDOW", self._on_close)

        pandas_note = "" if PANDAS_AVAILABLE else "  (!) pandas/openpyxl no instalados, no se podra exportar"
        self.log_queue.put((time.time(), "END", f"Los .xlsx se guardaran en: {LOG_DIR}{pandas_note}"))

