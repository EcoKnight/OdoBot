# ----------------------------------------------------------------------
# Cliente TCP: corre en un hilo aparte, nunca toca la GUI directamente
# ----------------------------------------------------------------------
class RobotClient:
    def __init__(self, data_queue: queue.Queue, status_callback, log_queue: queue.Queue = None,
                 end_callback=None, tare_ack_callback=None):
        self.sock = None
        self.connected = False
        self.data_queue = data_queue
        self.status_callback = status_callback  # fn(connected: bool, msg: str)
        self.log_queue = log_queue  # cola de lineas crudas TX/RX para el monitor serial
        self.end_callback = end_callback  # fn() -> llamada cuando llega "END"
        self.tare_ack_callback = tare_ack_callback  # fn() -> llamada al confirmar el Tara
        self._recv_thread = None
        self._stop_event = threading.Event()
        self._buffer = ""

    def _log(self, direction: str, text: str):
        if self.log_queue is not None:
            self.log_queue.put((time.time(), direction, text))

    def connect(self, ip: str, port: int) -> bool:
        if self.connected:
            return True
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(5)
            s.connect((ip, port))
            s.settimeout(None)
            self.sock = s
            self.connected = True
            self._stop_event.clear()
            self._buffer = ""
            self._recv_thread = threading.Thread(target=self._recv_loop, daemon=True)
            self._recv_thread.start()
            self.status_callback(True, f"Conectado a {ip}:{port}")
            return True
        except Exception as e:
            self.status_callback(False, f"No se pudo conectar: {e}")
            self.sock = None
            self.connected = False
            return False

    def disconnect(self):
        self._stop_event.set()
        self.connected = False
        if self.sock:
            try:
                self.sock.shutdown(socket.SHUT_RDWR)
            except OSError:
                pass
            try:
                self.sock.close()
            except OSError:
                pass
        self.sock = None
        self.status_callback(False, "Desconectado")

    def _recv_loop(self):
        while not self._stop_event.is_set():
            try:
                chunk = self.sock.recv(1024)
                if not chunk:
                    break
                self._buffer += chunk.decode("ascii", errors="ignore")
                # Reensamblado: solo procesamos lineas completas (terminadas en \n)
                while "\n" in self._buffer:
                    line, self._buffer = self._buffer.split("\n", 1)
                    line = line.strip()
                    if line:
                        self._log("RX", line)
                        self._process_line(line)
            except OSError:
                break
            except Exception as e:
                print(f"[RobotClient] Error de lectura: {e}")
                break

        was_connected = self.connected
        self.connected = False
        if was_connected and not self._stop_event.is_set():
            # se cayo la conexion sola (no fue un disconnect() manual)
            self.status_callback(False, "Conexion perdida con el robot")

    def _process_line(self, line: str):
        stripped = line.strip()
        upper = stripped.upper()

        if upper == "END":
            self._log("END", "Trayectoria finalizada (END)")
            if self.end_callback is not None:
                self.end_callback()
            return

        if TARE_ACK_TEXT in upper:
            self._log("ACK", stripped)
            if self.tare_ack_callback is not None:
                self.tare_ack_callback()
            return

        parts = stripped.split(",")
        if len(parts) < 7:
            self._log("ERR", f"Paquete incompleto ({len(parts)} campos): {line}")
            return  # paquete incompleto/corrupto, se descarta
        try:
            data = {
                "t": time.time(),
                "x": float(parts[0]),
                "y": float(parts[1]),
                "vel_der": float(parts[2]),
                "vel_izq": float(parts[3]),
                "pwm_der": int(float(parts[4])),
                "pwm_izq": int(float(parts[5])),
                "yaw": float(parts[6]),
                "us": float(parts[7]) if len(parts) > 7 else None,
            }
        except ValueError:
            self._log("ERR", f"Campo no numerico: {line}")
            return  # campo no numerico, se descarta la linea
        self.data_queue.put(data)

    def send_command(self, cmd: str) -> bool:
        if not self.connected or not self.sock:
            return False
        try:
            self.sock.sendall((cmd + "\n").encode("ascii"))
            self._log("TX", cmd)
            return True
        except Exception as e:
            self.status_callback(self.connected, f"Error enviando comando: {e}")
            self._log("ERR", f"Fallo enviando '{cmd}': {e}")
            return False


