    # ------------------------------------------------------------------
    # Drenado de la cola de datos (corre en el hilo principal de la GUI)
    # ------------------------------------------------------------------
    def _drain_queue(self):
        latest = None
        drained = 0
        try:
            while True:
                data = self.data_queue.get_nowait()
                latest = data
                drained += 1
                if self.t0 is None:
                    self.t0 = data["t"]
                self.traj_x.append(data["x"])
                self.traj_y.append(data["y"])
                self.time_hist.append((data["t"] - self.t0) * 1000.0)
                self.veld_hist.append(data["vel_der"])
                self.veli_hist.append(data["vel_izq"])
                self.yaw_hist.append(data["yaw"])

                if self.trajectory_active:
                    self.sequence_log.append({
                        "Tiempo (ms)": self.sequence_time_ms,
                        "Pos X (m)": data["x"],
                        "Pos Y (m)": data["y"],
                        "Vel Der": data["vel_der"],
                        "PWM_Der": data["pwm_der"],
                        "Vel Izq": data["vel_izq"],
                        "PWM_Izq": data["pwm_izq"],
                        "Theta (°)": data["yaw"],
                    })
                    self.sequence_time_ms += 20
        except queue.Empty:
            pass

        if latest is not None:
            self.last_data = latest
            self._update_telemetry_labels(latest)

        self.after(GUI_REFRESH_MS, self._drain_queue)

    def _update_telemetry_labels(self, data):
        self.value_labels["x"].config(text=f"{data['x']:.3f}")
        self.value_labels["y"].config(text=f"{data['y']:.3f}")
        self.value_labels["vel_der"].config(text=f"{data['vel_der']:.2f}")
        self.value_labels["vel_izq"].config(text=f"{data['vel_izq']:.2f}")
        self.value_labels["pwm_der"].config(text=str(data["pwm_der"]))
        self.value_labels["pwm_izq"].config(text=str(data["pwm_izq"]))
        self.value_labels["yaw"].config(text=f"{data['yaw']:.2f}")
        self.value_labels["us"].config(text=f"{data['us']:.1f}" if data["us"] is not None else "N/A")
        self.last_update_lbl.config(text=f"Ultimo paquete: {datetime.now().strftime('%H:%M:%S')}")

    # ------------------------------------------------------------------
    # Redibujo de graficas (mas lento que el drenado de datos)
    # ------------------------------------------------------------------
    def _refresh_plots(self):
        if self.traj_x:
            self.traj_line.set_data(self.traj_x, self.traj_y)
            self.traj_point.set_data([self.traj_x[-1]], [self.traj_y[-1]])
            if self.map_autoscale_var.get():
                self.ax_traj.relim()
                self.ax_traj.autoscale_view()
            else:
                # Limites fijos (recomendado por la ficha tecnica) para evitar
                # que el mapa "salte" de zoom en cada iteracion. Si la
                # trayectoria se sale del rango, lo ampliamos con margen.
                max_extent = max(abs(v) for v in self.traj_x + self.traj_y) if (self.traj_x or self.traj_y) else 0
                limit = max(MAP_FIXED_LIMIT_M, max_extent * 1.15)
                self.ax_traj.set_xlim(-limit, limit)
                self.ax_traj.set_ylim(-limit, limit)
            self.canvas_traj.draw_idle()

        if self.time_hist:
            t = list(self.time_hist)
            self.line_veld.set_data(t, list(self.veld_hist))
            self.line_veli.set_data(t, list(self.veli_hist))
            self.line_yaw.set_data(t, list(self.yaw_hist))

            if self.setpoint_yaw is not None:
                self.line_yawsp.set_data([t[0], t[-1]], [self.setpoint_yaw, self.setpoint_yaw])
            if self.setpoint_vel is not None:
                self.line_velsp.set_data([t[0], t[-1]], [self.setpoint_vel, self.setpoint_vel])

            for ax in (self.ax_vel, self.ax_yaw):
                ax.relim()
                ax.autoscale_view()
            self.canvas_time.draw_idle()

        self.after(PLOT_REFRESH_MS, self._refresh_plots)

    # ------------------------------------------------------------------
    # Guardar / borrar mapa
    # ------------------------------------------------------------------
    def _save_map(self):
        if not self.traj_x:
            messagebox.showinfo("Sin datos", "Todavia no hay trayectoria que guardar.")
            return

        default_name = f"trayectoria_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
        path = filedialog.asksaveasfilename(
            title="Guardar mapa de trayectoria",
            initialfile=default_name,
            defaultextension=".png",
            filetypes=[("Imagen PNG", "*.png"), ("CSV de puntos", "*.csv")],
        )
        if not path:
            return

        try:
            if path.lower().endswith(".csv"):
                with open(path, "w", newline="", encoding="utf-8") as f:
                    writer = csv.writer(f)
                    writer.writerow(["X", "Y"])
                    writer.writerows(zip(self.traj_x, self.traj_y))
            else:
                self.fig_traj.savefig(path, facecolor=self.fig_traj.get_facecolor(), dpi=150)
                # ademas del PNG, guarda automaticamente un CSV junto a el
                csv_path = os.path.splitext(path)[0] + ".csv"
                with open(csv_path, "w", newline="", encoding="utf-8") as f:
                    writer = csv.writer(f)
                    writer.writerow(["X", "Y"])
                    writer.writerows(zip(self.traj_x, self.traj_y))
            messagebox.showinfo("Guardado", f"Mapa guardado en:\n{path}")
        except Exception as e:
            messagebox.showerror("Error al guardar", str(e))

    def _clear_map(self):
        if not self.traj_x:
            return
        if not messagebox.askyesno("Borrar mapa", "Esto borra la trayectoria mostrada (no afecta al robot). Continuar?"):
            return
        self.traj_x.clear()
        self.traj_y.clear()
        self.traj_line.set_data([], [])
        self.traj_point.set_data([], [])
        if self.map_autoscale_var.get():
            self.ax_traj.relim()
            self.ax_traj.autoscale_view()
        else:
            self.ax_traj.set_xlim(-MAP_FIXED_LIMIT_M, MAP_FIXED_LIMIT_M)
            self.ax_traj.set_ylim(-MAP_FIXED_LIMIT_M, MAP_FIXED_LIMIT_M)
        self.canvas_traj.draw_idle()

    # ------------------------------------------------------------------
    def _on_close(self):
        self.client.disconnect()
        self.destroy()


