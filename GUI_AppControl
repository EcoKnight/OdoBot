        self.cart_preview_lbl.grid(row=3, column=0, columnspan=2, sticky="w", pady=(6, 0))

    # ------------------------------------------------------------------
    def _require_connection(self) -> bool:
        if not self.client.connected:
            messagebox.showwarning("Sin conexion", "Primero conecta con el robot.")
            return False
        return True

    def _parse_fields(self, specs):
        """specs: lista de (StringVar, nombre_campo). Devuelve lista de floats
        o None si algun campo es invalido (mostrando un solo dialogo de error)."""
        values = []
        for var, name in specs:
            try:
                values.append(float(var.get()))
            except ValueError:
                messagebox.showerror("Datos invalidos", f"'{name}' debe ser numerico.")
                return None
        return values

    # ------------------------------------------------------------------
    # Estado de Ejecucion: arma la lista de comandos segun el modo activo
    # ------------------------------------------------------------------
    def _start_test(self):
        if not self._require_connection():
            return
        if self.trajectory_active:
            messagebox.showwarning("Prueba en curso", "Espera a que termine la prueba actual.")
            return
        if self.tara_waiting:
            messagebox.showwarning("Tarea en curso", "Espera la confirmacion del Tarea antes de iniciar.")
            return

        mode_idx = self.mode_notebook.index(self.mode_notebook.select())
        builder = (self._build_commands_libre, self._build_commands_dinamica,
                   self._build_commands_cuadrado, self._build_commands_cartesiano)[mode_idx]
        result = builder()
        if result is None:
            return  # error de validacion ya mostrado al usuario
        commands, base_name = result
        self._start_sequence(commands, base_name)

    def _build_commands_libre(self):
        vals = self._parse_fields([(self.vel_var, "Velocidad"), (self.ang_var, "Angulo"), (self.dur_var, "Duracion")])
        if vals is None:
            return None
        vel, ang, dur = vals
        return [f"P,{vel:g},{ang:g},{dur:g}"], "Prueba_Libre"

    def _build_commands_dinamica(self):
        vals = self._parse_fields([
            (self.din_v1_var, "Velocidad 1"), (self.din_v2_var, "Velocidad 2"),
            (self.din_v3_var, "Velocidad 3"), (self.din_ang_var, "Angulo constante"),
            (self.din_dur_var, "Duracion total"),
        ])
        if vals is None:
            return None
        v1, v2, v3, ang, dur_total = vals
        t_tramo = dur_total / 3.0
        commands = [f"P,{v:g},{ang:g},{t_tramo:g}" for v in (v1, v2, v3)]
        return commands, "Prueba_Dinamica"

    def _build_commands_cuadrado(self):
        vals = self._parse_fields([(self.cuad_vel_var, "Velocidad de crucero"), (self.cuad_tlado_var, "Tiempo por lado")])
        if vals is None:
            return None
        sp, t_lado = vals
        # Secuencia para trazar un cuadrado continuo a la derecha (horario)
        commands = [
            f"P,{sp:g},90,{t_lado:g}",     # Lado 1: hacia adelante (Y+)
            f"P,{sp:g},0,{t_lado:g}",      # Lado 2: gira 90 der (X+)
            f"P,{sp:g},-90,{t_lado:g}",    # Lado 3: gira 90 der (Y-)
            f"P,{sp:g},-180,{t_lado:g}",   # Lado 4: gira 90 der (X-)
            "P,0,-270,2",                   # Extra: gira 90 der para volver al frente
        ]
        return commands, "Prueba_Cuadrado_Der"

    def _build_commands_cartesiano(self):
        vals = self._parse_fields([
            (self.cart_dx_var, "Desplazamiento X"), (self.cart_dy_var, "Desplazamiento Y"),
            (self.cart_vel_var, "Velocidad de crucero"),
        ])
        if vals is None:
            return None
        dx, dy, sp = vals
        if sp == 0:
            messagebox.showerror("Datos invalidos", "La velocidad de crucero no puede ser 0.")
            return None

        distancia_m = math.sqrt(dx ** 2 + dy ** 2)
        angulo_deg = math.degrees(math.atan2(dy, dx))
        vel_m_s = sp * TICKS_A_METROS
        duracion = distancia_m / vel_m_s

        self.cart_preview_lbl.config(
            text=(f"Distancia: {distancia_m:.3f} m  |  Angulo: {angulo_deg:.2f}deg  |  "
                  f"Tiempo: {duracion:.2f} s")
        )
        commands = [f"P,{int(sp)},{angulo_deg:.2f},{duracion:.3f}"]
        return commands, "Trayectoria_Cartesiana"

    # ------------------------------------------------------------------
    # Secuencia de comandos encadenados por la senal END
    # ------------------------------------------------------------------
    def _start_sequence(self, commands, base_name):
        self.command_sequence = deque(commands)
        self.sequence_total = len(commands)
        self.sequence_base_name = base_name
        self.sequence_log = []
        self.sequence_time_ms = 0
        self._set_trajectory_active(True)
        self._send_next_in_sequence()

    def _send_next_in_sequence(self):
        if not self.command_sequence:
            self._finish_sequence()
            return
        cmd = self.command_sequence.popleft()
        done = self.sequence_total - len(self.command_sequence)
        if self.client.send_command(cmd):
            self.last_cmd_lbl.config(text=f"Ultimo comando: {cmd}")
            parts = cmd.split(",")
            if len(parts) >= 3:
                try:
                    self.setpoint_vel = float(parts[1])
                    self.setpoint_yaw = float(parts[2])
                except ValueError:
                    pass
            self.trajectory_status_lbl.config(
                text=f"Tramo {done}/{self.sequence_total} en curso... esperando END",
                foreground=ACCENT,
            )
        else:
            # fallo el envio (p.ej. se perdio la conexion a media secuencia)
            messagebox.showerror("Error de envio", f"No se pudo enviar el comando: {cmd}")
            self.command_sequence.clear()
            self._finish_sequence(save_excel=bool(self.sequence_log))

    def _on_trajectory_end(self):
        # Se llama desde el hilo de red -> siempre via .after()
        def update():
            if not self.trajectory_active:
                return  # END fuera de una secuencia activa, se ignora
            if self.command_sequence:
                self._send_next_in_sequence()
            else:
                self._finish_sequence()
        self.after(0, update)

    def _finish_sequence(self, save_excel: bool = True):
        self._set_trajectory_active(False)
        if save_excel and self.sequence_log:
            self.trajectory_status_lbl.config(text="Secuencia finalizada, guardando Excel...", foreground=OK_COLOR)
            log_copy = list(self.sequence_log)
            base_name = self.sequence_base_name
            self.sequence_log = []
            threading.Thread(target=self._save_excel_background, args=(log_copy, base_name), daemon=True).start()
        elif save_excel:
            # La secuencia termino pero no se acumulo ninguna fila de telemetria
            # (posible perdida de datos o el robot no envio CSV durante la prueba)
            self.trajectory_status_lbl.config(text="Secuencia finalizada, SIN datos que guardar", foreground=ERR_COLOR)
            messagebox.showwarning(
                "Sin telemetria",
                "La secuencia termino pero no se recibio ningun paquete de telemetria durante la prueba,"
                " asi que no se genero ningun Excel. Revisa la conexion y que el robot este transmitiendo."
            )
        else:
            self.trajectory_status_lbl.config(text="Secuencia finalizada (END)", foreground=OK_COLOR)

    def _save_excel_background(self, log_rows, base_name):
        if not PANDAS_AVAILABLE:
            self.after(0, lambda: self._on_excel_error(
                "Falta instalar pandas y openpyxl. Corre: pip install pandas openpyxl"))
            return
        try:
            os.makedirs(LOG_DIR, exist_ok=True)
            timestamp = time.strftime("%H%M%S")
            filename = os.path.join(LOG_DIR, f"{base_name}_{timestamp}.xlsx")
            df = pd.DataFrame(log_rows)
            df.to_excel(filename, index=False)
            self.after(0, lambda: self._on_excel_saved(filename))
        except Exception as e:
            self.after(0, lambda: self._on_excel_error(str(e)))

    def _on_excel_saved(self, filename):
        self.trajectory_status_lbl.config(text=f"Excel guardado: {os.path.basename(filename)}", foreground=OK_COLOR)
        if self.log_queue is not None:
            self.log_queue.put((time.time(), "END", f"Excel guardado en {filename}"))
        messagebox.showinfo("Excel guardado", f"Se guardo la telemetria de la prueba en:\n\n{filename}")

    def _on_excel_error(self, msg):
        self.trajectory_status_lbl.config(text="Error guardando Excel (ver monitor)", foreground=ERR_COLOR)
        if self.log_queue is not None:
            self.log_queue.put((time.time(), "ERR", f"No se pudo guardar el Excel: {msg}"))
        messagebox.showerror("Error al guardar Excel", msg)

    # ------------------------------------------------------------------
    # Estado de Calibracion (Tara/Home) con espera de confirmacion
    # ------------------------------------------------------------------
    def _send_r_command(self):
        if not self._require_connection():
            return
        if self.trajectory_active:
            messagebox.showwarning("Prueba en curso", "Espera a que termine la prueba actual antes de tarar.")
            return
        self._tara_token += 1
        token = self._tara_token
        if self.client.send_command("R"):
            self.last_cmd_lbl.config(text="Ultimo comando: R (tara/home)")
            self.setpoint_yaw = 90.0
            self._set_tara_waiting(True)
            self.after(TARE_TIMEOUT_MS, lambda: self._check_tara_timeout(token))

    def _set_tara_waiting(self, waiting: bool):
        self.tara_waiting = waiting
        state = "disabled" if waiting else "normal"
        self.tare_btn.config(state=state)
        if not self.trajectory_active:
            self.start_test_btn.config(state=state)
        if waiting:
            self.trajectory_status_lbl.config(text="Esperando confirmacion de tara...", foreground=ACCENT)
        elif not self.trajectory_active:
            self.trajectory_status_lbl.config(text="")

    def _on_tare_ack(self):
        # Se llama desde el hilo de red -> siempre via .after()
        def update():
            if self.tara_waiting:
                self._set_tara_waiting(False)
                self.trajectory_status_lbl.config(text="Sistema de referencia OK", foreground=OK_COLOR)
        self.after(0, update)

    def _check_tara_timeout(self, token):
        if self.tara_waiting and token == self._tara_token:
            self._set_tara_waiting(False)
            self.trajectory_status_lbl.config(text="Sin confirmacion del robot (timeout)", foreground=ERR_COLOR)

    def _send_raw_command(self):
        if not self._require_connection():
            return
        cmd = self.raw_cmd_var.get().strip()
        if not cmd:
            return
        if self.client.send_command(cmd):
            self.last_cmd_lbl.config(text=f"Ultimo comando: {cmd}")
            self.raw_cmd_var.set("")

    def _set_trajectory_active(self, active: bool):
        """Deshabilita/habilita los botones de envio mientras el robot
        esta ejecutando una prueba (entre el primer comando P y el
        agotamiento de la secuencia via senales END)."""
        self.trajectory_active = active
        state = "disabled" if active else "normal"
        self.start_test_btn.config(state=state)
        self.tare_btn.config(state=state)
        if active:
            self.trajectory_status_lbl.config(text="Prueba en curso... esperando END", foreground=ACCENT)
        else:
            self.trajectory_status_lbl.config(text="")

