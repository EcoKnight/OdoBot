    def _drain_log_queue(self):
        new_entries = []
        try:
            while True:
                new_entries.append(self.log_queue.get_nowait())
        except queue.Empty:
            pass

        if new_entries and not self.pause_var.get():
            self.monitor_text.config(state="normal")
            for ts, direction, text in new_entries:
                tag = {"TX": "tx", "RX": "rx", "ERR": "err", "END": "end", "ACK": "ack"}.get(direction, "rx")
                prefix = {"TX": ">> ", "RX": "<< ", "ERR": "!! ", "END": "== ", "ACK": "** "}.get(direction, "")
                t_str = datetime.fromtimestamp(ts).strftime("%H:%M:%S.%f")[:-3]
                line = f"[{t_str}] {prefix}{text}\n"
                self._monitor_lines.append(line)
                self.monitor_text.insert("end", f"[{t_str}] ", "ts")
                self.monitor_text.insert("end", f"{prefix}{text}\n", tag)

            # limita el historial visible para no consumir memoria/CPU sin fin
            max_lines = 1000
            line_count = int(self.monitor_text.index("end-1c").split(".")[0])
            if line_count > max_lines:
                self.monitor_text.delete("1.0", f"{line_count - max_lines}.0")
            if len(self._monitor_lines) > max_lines:
                self._monitor_lines = self._monitor_lines[-max_lines:]

            if self.autoscroll_var.get():
                self.monitor_text.see("end")
            self.monitor_text.config(state="disabled")

        self.after(GUI_REFRESH_MS, self._drain_log_queue)

    def _clear_monitor(self):
        self.monitor_text.config(state="normal")
        self.monitor_text.delete("1.0", "end")
        self.monitor_text.config(state="disabled")
        self._monitor_lines.clear()

    def _save_monitor_log(self):
        if not self._monitor_lines:
            messagebox.showinfo("Sin datos", "El monitor esta vacio.")
            return
        path = filedialog.asksaveasfilename(
            title="Guardar log del monitor",
            initialfile=f"log_{datetime.now().strftime('%Y%m%d_%H%M%S')}.txt",
            defaultextension=".txt",
            filetypes=[("Texto", "*.txt")],
        )
        if not path:
            return
        try:
            with open(path, "w", encoding="utf-8") as f:
                f.writelines(self._monitor_lines)
            messagebox.showinfo("Guardado", f"Log guardado en:\n{path}")
        except Exception as e:
            messagebox.showerror("Error al guardar", str(e))


