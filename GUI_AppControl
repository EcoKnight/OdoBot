    # Estilo
    # ------------------------------------------------------------------
    def _setup_style(self):
        style = ttk.Style(self)
        try:
            style.theme_use("clam")
        except tk.TclError:
            pass
        style.configure("TFrame", background=PANEL_BG)
        style.configure("TLabel", background=PANEL_BG, foreground=FG, font=("Segoe UI", 10))
        style.configure("Title.TLabel", background=PANEL_BG, foreground=ACCENT, font=("Segoe UI", 12, "bold"))
        style.configure("Value.TLabel", background=PANEL_BG, foreground=FG, font=("Consolas", 16, "bold"))
        style.configure("Unit.TLabel", background=PANEL_BG, foreground="#9e9e9e", font=("Segoe UI", 8))
        style.configure("TButton", font=("Segoe UI", 10), padding=6)
        style.configure("TEntry", padding=4)
        style.configure("TNotebook", background=BG, borderwidth=0)
        style.configure("TNotebook.Tab", padding=(14, 6), font=("Segoe UI", 10))

    # ------------------------------------------------------------------
    # Layout general
    # ------------------------------------------------------------------
    def _build_layout(self):
        # ---- Barra superior: conexion ----
        top = tk.Frame(self, bg=PANEL_BG, padx=10, pady=8)
        top.pack(side="top", fill="x")
        self._build_connection_bar(top)

        # ---- Cuerpo: panel izquierdo (telemetria + comandos) / derecho (graficas) ----
        body = tk.Frame(self, bg=BG)
        body.pack(side="top", fill="both", expand=True, padx=8, pady=8)

        left = tk.Frame(body, bg=BG, width=460)
        left.pack(side="left", fill="y", padx=(0, 8))
        left.pack_propagate(False)

        right = tk.Frame(body, bg=BG)
        right.pack(side="left", fill="both", expand=True)

        self._build_telemetry_panel(left)
        self._build_command_panel(left)
        self._build_monitor_panel(left)
        self._build_plots(right)

    # ------------------------------------------------------------------
    # Barra de conexion
    # ------------------------------------------------------------------
    def _build_connection_bar(self, parent):
        tk.Label(parent, text="IP:", bg=PANEL_BG, fg=FG).pack(side="left")
        self.ip_var = tk.StringVar(value=DEFAULT_IP)
        ttk.Entry(parent, textvariable=self.ip_var, width=14).pack(side="left", padx=(4, 10))

        tk.Label(parent, text="Puerto:", bg=PANEL_BG, fg=FG).pack(side="left")
        self.port_var = tk.StringVar(value=str(DEFAULT_PORT))
        ttk.Entry(parent, textvariable=self.port_var, width=7).pack(side="left", padx=(4, 10))

        self.connect_btn = ttk.Button(parent, text="Conectar", command=self._toggle_connection)
        self.connect_btn.pack(side="left", padx=(0, 14))

        self.status_dot = tk.Canvas(parent, width=14, height=14, bg=PANEL_BG, highlightthickness=0)
        self.status_dot.pack(side="left")
        self._dot = self.status_dot.create_oval(2, 2, 12, 12, fill=ERR_COLOR, outline="")

        self.status_label = tk.Label(parent, text="Desconectado", bg=PANEL_BG, fg=FG)
        self.status_label.pack(side="left", padx=(6, 0))

    def _toggle_connection(self):
        if self.client.connected:
            self.client.disconnect()
            self.connect_btn.config(text="Conectar")
            self._set_trajectory_active(False)
            self._set_tara_waiting(False)
            return
        ip = self.ip_var.get().strip()
        try:
            port = int(self.port_var.get().strip())
        except ValueError:
            messagebox.showerror("Puerto invalido", "El puerto debe ser un numero entero.")
            return

        self.connect_btn.config(text="Conectando...", state="disabled")
        self.update_idletasks()

        def worker():
            ok = self.client.connect(ip, port)
            self.after(0, lambda: self._post_connect_ui(ok))

        threading.Thread(target=worker, daemon=True).start()

    def _post_connect_ui(self, ok: bool):
        self.connect_btn.config(state="normal")
        self.connect_btn.config(text="Desconectar" if ok else "Conectar")
        if ok:
            self.t0 = None  # reinicia el eje de tiempo de las graficas

    def _on_status_change(self, connected: bool, msg: str):
        # Puede llamarse desde el hilo de red -> siempre via .after()
        def update():
            self.status_label.config(text=msg)
            self.status_dot.itemconfig(self._dot, fill=OK_COLOR if connected else ERR_COLOR)
            if not connected:
                self.connect_btn.config(text="Conectar")
        self.after(0, update)

    # ------------------------------------------------------------------
    # Panel de telemetria
    # ------------------------------------------------------------------
    def _build_telemetry_panel(self, parent):
        frame = tk.Frame(parent, bg=PANEL_BG, padx=12, pady=10)
        frame.pack(side="top", fill="x")

        ttk.Label(frame, text="TELEMETRIA", style="Title.TLabel").grid(row=0, column=0, columnspan=2, sticky="w", pady=(0, 8))

        fields = [
            ("x", "Pos. X", "m"),
            ("y", "Pos. Y", "m"),
            ("vel_der", "Vel. Derecha", "ticks/s"),
            ("vel_izq", "Vel. Izquierda", "ticks/s"),
            ("pwm_der", "PWM Derecho", "0-4095"),
            ("pwm_izq", "PWM Izquierdo", "0-4095"),
            ("yaw", "Yaw (IMU)", "deg"),
            ("us", "Distancia US", "cm"),
        ]
        self.value_labels = {}
        for i, (key, label, unit) in enumerate(fields):
            r = i + 1
            ttk.Label(frame, text=label).grid(row=r, column=0, sticky="w", pady=3)
            val_lbl = ttk.Label(frame, text="--", style="Value.TLabel")
            val_lbl.grid(row=r, column=1, sticky="e", pady=3)
            unit_lbl = ttk.Label(frame, text=unit, style="Unit.TLabel")
            unit_lbl.grid(row=r, column=2, sticky="w", padx=(4, 0))
            self.value_labels[key] = val_lbl

        frame.columnconfigure(1, weight=1)

        self.last_update_lbl = ttk.Label(frame, text="Ultimo paquete: --", style="Unit.TLabel")
        self.last_update_lbl.grid(row=len(fields) + 1, column=0, columnspan=3, sticky="w", pady=(8, 0))

