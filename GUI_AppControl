TIME_WINDOW_POINTS = 1000  # puntos visibles en graficas de tiempo (ventana deslizante)

MAP_FIXED_LIMIT_M = 2.0   # limites fijos por defecto del mapa cartesiano (+-2 m)

TARE_ACK_TEXT = "SISTEMA DE REFERENCIA OK"
TARE_TIMEOUT_MS = 5000    # espera maxima por la confirmacion del Tara

# Constantes mecanicas de Chrome, usadas por el Modo Cartesiano (cinematica inversa)
R_RUEDA_M = 0.034025
TICKS_POR_REV = 2472.8
TICKS_A_METROS = (2.0 * math.pi * R_RUEDA_M) / TICKS_POR_REV

LOG_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "logs")

